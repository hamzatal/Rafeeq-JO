{
  "name": "rafeeq-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Rafeeq — Smart University Mobility & Services Platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "student": "npm run start --workspace=apps/student-app",
    "driver": "npm run start --workspace=apps/driver-app",
    "admin": "npm run dev --workspace=apps/admin-dashboard",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.0.0",
  "license": "UNLICENSED",
  "dependencies": {
    "react-dom": "18.2.0",
    "react-native-web": "~0.19.10"
  }
}
