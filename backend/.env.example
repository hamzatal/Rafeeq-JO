APP_NAME=Rafeeq
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Amman
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_JO

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# ───────── Database (PostgreSQL + PostGIS) ─────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=rafeeq
DB_USERNAME=rafeeq
DB_PASSWORD=secret

# ───────── Redis ─────────
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ───────── Cache / Queue / Session ─────────
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ───────── Sanctum / Auth ─────────
SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost:19006
SANCTUM_TOKEN_EXPIRATION=43200
SANCTUM_TOKEN_PREFIX=rfq_

# ───────── CORS ─────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

# ───────── Mail (Mailpit local) ─────────
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_FROM_ADDRESS="no-reply@rafeeq.jo"
MAIL_FROM_NAME="${APP_NAME}"

# ───────── OTP ─────────
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# ───────── SMS ─────────
SMS_DRIVER=log
SMS_SENDER_ID=Rafeeq
SMS_API_KEY=
SMS_BASE_URL=

# ───────── OpenAI (GPT) ─────────
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o

# ───────── CliQ (Payments) ─────────
CLIQ_ALIAS=
CLIQ_BANK_NAME=
CLIQ_BENEFICIARY_NAME=
CLIQ_REQUEST_TTL=1440

# ───────── Firebase (Push) ─────────
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS=

# ───────── Maps ─────────
MAPS_PROVIDER=google
GOOGLE_MAPS_KEY=
MAPBOX_TOKEN=

# ───────── Secure Storage (S3/MinIO) ─────────
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=rafeeq
AWS_SECRET_ACCESS_KEY=secret123
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=rafeeq-secure
AWS_ENDPOINT=http://127.0.0.1:9000
AWS_USE_PATH_STYLE_ENDPOINT=true
