# ── Rafeeq — PRODUCTION environment template ──────────────────────────
# Copy to .env.production and fill via your secrets manager. NEVER commit real values.

APP_NAME=Rafeeq
APP_ENV=production
APP_KEY=                      # php artisan key:generate --show
APP_DEBUG=false               # MUST be false in production
APP_URL=https://api.rafeeq.jo
APP_LOCALE=ar

# Force HTTPS + secure cookies
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# Database (PostgreSQL + PostGIS)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=rafeeq
DB_USERNAME=rafeeq
DB_PASSWORD=                  # strong secret

# Redis (cache / queue / broadcast / sessions)
REDIS_HOST=redis
REDIS_PASSWORD=               # strong secret
REDIS_PORT=6379
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
BROADCAST_CONNECTION=reverb

# Sanctum
SANCTUM_TOKEN_EXPIRATION=43200
SANCTUM_TOKEN_PREFIX=rfq_

# Object storage (documents, payment proofs, parcels) — private bucket
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=true

# ── Integrations (optional — platform degrades gracefully without them) ──
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o

CLIQ_ALIAS=
CLIQ_BANK_NAME=
CLIQ_BENEFICIARY_NAME=
CLIQ_REQUEST_TTL=1440

FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS=         # path to mounted service-account json

SMS_DRIVER=http
SMS_API_KEY=
SMS_BASE_URL=
SMS_SENDER_ID=Rafeeq

# Reverb (realtime)
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=ws.rafeeq.jo
REVERB_PORT=443
REVERB_SCHEME=https

# Maps
MAPS_PROVIDER=google
GOOGLE_MAPS_KEY=
MAPBOX_TOKEN=

# Business settings (fils)
RAFEEQ_COMMISSION_PERCENT=15
RAFEEQ_DEFAULT_FARE_FILS=1000
RAFEEQ_EXPRESS_FEE_FILS=1500
RAFEEQ_MIN_FILL_RIDERS=3
RAFEEQ_MAX_SURGE_MULTIPLIER=1.5
