{
  "expo": {
    "name": "رفيق - ولي الأمر",
    "slug": "rafeeq-guardian",
    "scheme": "rafeeqguardian",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0E2A47"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "jo.rafeeq.guardian"
    },
    "android": {
      "package": "jo.rafeeq.guardian",
      "adaptiveIcon": {
        "backgroundColor": "#0E2A47"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": ["expo-router", "expo-secure-store", "expo-font"],
    "extra": {
      "apiUrl": "http://localhost:8000"
    }
  }
}
