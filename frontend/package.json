{
  "name": "rafeeq-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Rafeeq frontend workspace (student, driver, admin + shared packages)",
  "workspaces": [
    "student-app",
    "driver-app",
    "guardian-app",
    "admin-dashboard",
    "packages/*"
  ],
  "scripts": {
    "student": "npm run start --workspace=student-app",
    "driver": "npm run start --workspace=driver-app",
    "guardian": "npm run start --workspace=guardian-app",
    "admin": "npm run dev --workspace=admin-dashboard",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.0.0",
  "license": "UNLICENSED",
  "overrides": {
    "@types/react": "18.2.79",
    "@types/react-dom": "18.3.7",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "dependencies": {
    "react-dom": "18.2.0",
    "react-native-web": "~0.19.10"
  }
}
