{
  "expo": {
    "name": "رفيق",
    "slug": "rafeeq-student",
    "scheme": "rafeeq",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#002045"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "jo.rafeeq.student"
    },
    "android": {
      "package": "jo.rafeeq.student",
      "adaptiveIcon": {
        "backgroundColor": "#002045"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "يستخدم رفيق موقعك لتحديد نقطة الالتقاط وإرساله مع نداء الطوارئ."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#006A65"
        }
      ]
    ],
    "extra": {
      "apiUrl": "http://localhost:8000",
      "mapsKey": ""
    }
  }
}
