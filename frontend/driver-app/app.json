{
  "expo": {
    "name": "رفيق كابتن",
    "slug": "rafeeq-driver",
    "scheme": "rafeeqdriver",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#141B2E"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "jo.rafeeq.driver"
    },
    "android": {
      "package": "jo.rafeeq.driver",
      "adaptiveIcon": {
        "backgroundColor": "#141B2E"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-image-picker",
      "expo-document-picker",
      [
        "expo-notifications",
        {
          "color": "#E7A63A"
        }
      ],
      "expo-sharing",
      "expo-splash-screen",
      "expo-status-bar"
    ],
    "extra": {
      "apiUrl": "http://localhost:8000"
    }
  }
}
